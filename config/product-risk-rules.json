      "category": "brand_logo_or_infringement_risk",
      "severity": "review",
      "fields": [
        "title",
        "brand",
        "bullets",
        "description",
        "imageAlt",
        "imageNotes"
      ],
      "terms": [
        "logo",
        "brand logo",
        "trademark",
        "branded",
        "officially licensed",
        "licensed product",
        "copyright",
        "patent",
        "watermark",
        "商标",
        "品牌",
        "授权",
        "正版",
        "水印"
      ],
      "reason": "Product text or visual notes mention logo, trademark, licensing, or brand packaging.",
      "nextAction": "manual_visual_logo_review"
    },
